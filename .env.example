# OKAR - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# Base de données SQLite (fichier local)
DATABASE_URL="file:/app/data/okar.db"

# Secrets (générez avec: openssl rand -base64 32)
NEXTAUTH_SECRET="votre-secret-nextauth-ici"
JWT_SECRET="votre-secret-jwt-ici"

# URL de votre application
NEXTAUTH_URL="https://votre-domaine.com"

# Port (3001 car QRBag utilise 3000)
PORT=3001
